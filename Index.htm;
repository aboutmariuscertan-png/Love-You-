<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Te Iubesc</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Cinzel:wght@400;600&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
html, body {
  width: 100%; height: 100%;
  overflow: hidden;
  background: #04010a;
  font-family: 'Cormorant Garamond', serif;
}
canvas { display: block; position: fixed; top: 0; left: 0; }

#ui {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 5vh;
  pointer-events: none;
}

.heart-icon {
  margin-bottom: 16px;
  animation: pulse-heart 1.6s ease-in-out infinite;
}
.heart-icon svg {
  width: 44px; height: 40px;
  filter: drop-shadow(0 0 12px rgba(230, 80, 120, 0.8)) drop-shadow(0 0 28px rgba(230, 80, 120, 0.4));
}

.message {
  font-family: 'Cinzel', serif;
  font-size: clamp(22px, 5vw, 38px);
  font-weight: 400;
  letter-spacing: 0.28em;
  color: #fff;
  text-transform: uppercase;
  text-shadow:
    0 0 20px rgba(230, 80, 120, 0.9),
    0 0 60px rgba(230, 80, 120, 0.5),
    0 0 100px rgba(230, 80, 120, 0.2);
  animation: fade-glow 3s ease-in-out infinite alternate;
}

.subtitle {
  margin-top: 10px;
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: clamp(13px, 2.5vw, 18px);
  letter-spacing: 0.18em;
  color: rgba(255,200,210,0.55);
  text-shadow: 0 0 20px rgba(230, 80, 120, 0.3);
  animation: fade-glow 3s ease-in-out infinite alternate;
  animation-delay: 0.5s;
}

@keyframes pulse-heart {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.18); }
}
@keyframes fade-glow {
  0% { opacity: 0.75; }
  100% { opacity: 1; }
}
</style>
</head>
<body>

<canvas id="c"></canvas>

<div id="ui">
  <div class="heart-icon">
    <svg viewBox="0 0 100 90" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M50 82 C50 82 5 52 5 28 C5 12 17 2 30 2 C38 2 44 6 50 13 C56 6 62 2 70 2 C83 2 95 12 95 28 C95 52 50 82 50 82Z"
        fill="url(#hg)" stroke="rgba(255,120,150,0.6)" stroke-width="0.8"/>
      <defs>
        <linearGradient id="hg" x1="50" y1="2" x2="50" y2="82" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#ff5580"/>
          <stop offset="100%" stop-color="#b81048"/>
        </linearGradient>
      </defs>
    </svg>
  </div>
  <div class="message">Te Iubesc</div>
  <div class="subtitle">pentru totdeauna &amp; mereu</div>
</div>

<script>
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');

const DPR = Math.min(window.devicePixelRatio || 1, 2);
let W, H, CX, CY, SCALE;

// ── Particles ──────────────────────────────────────────────────────────────
const PARTICLE_COUNT = 110;
const particles = [];

// floating background dust
const DUST_COUNT = 60;
const dust = [];

function heartXY(t) {
  const x = 16 * Math.pow(Math.sin(t), 3);
  const y = -(13*Math.cos(t) - 5*Math.cos(2*t) - 2*Math.cos(3*t) - Math.cos(4*t));
  return { x: x * SCALE, y: y * SCALE };
}

const WORDS = ['te iubesc', '❤', 'forever', 'mereu', '∞', '♡'];

class Particle {
  constructor(i) {
    this.i = i;
    this.reset(true);
  }
  reset(init = false) {
    const t = (this.i / PARTICLE_COUNT) * Math.PI * 2;
    this.targetT = t;
    const pos = heartXY(t);
    this.tx = CX + pos.x;
    this.ty = CY + pos.y * 0.92 - H * 0.06;

    if (init) {
      // start scattered
      const ang = Math.random() * Math.PI * 2;
      const r = Math.random() * Math.min(W, H) * 0.6;
      this.x = CX + Math.cos(ang) * r;
      this.y = CY + Math.sin(ang) * r;
    } else {
      this.x = this.tx + (Math.random() - 0.5) * 6;
      this.y = this.ty + (Math.random() - 0.5) * 6;
    }

    this.phase = Math.random() * Math.PI * 2;
    this.speed = 0.012 + Math.random() * 0.01;
    this.word = WORDS[Math.floor(Math.random() * WORDS.length)];
    this.fontSize = 10 + Math.random() * 5;
    this.alpha = 0.7 + Math.random() * 0.3;
    this.hue = 340 + Math.random() * 30; // pinks & reds
    this.lightness = 65 + Math.random() * 20;
  }
  update(t) {
    const pos = heartXY(this.targetT);
    const tx = CX + pos.x;
    const ty = CY + pos.y * 0.92 - H * 0.06;

    const pulse = 1 + Math.sin(t * 1.5 + this.phase) * 0.06;
    this.tx = CX + (tx - CX) * pulse;
    this.ty = CY + (ty - CY) * pulse;

    this.x += (this.tx - this.x) * this.speed;
    this.y += (this.ty - this.y) * this.speed;
  }
  draw(t) {
    const brightness = 0.75 + Math.sin(t * 1.8 + this.phase) * 0.25;
    const alpha = this.alpha * brightness;
    ctx.save();
    ctx.font = `${this.fontSize}px 'Cormorant Garamond', serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';

    // outer glow
    ctx.shadowColor = `hsla(${this.hue}, 90%, 60%, 0.7)`;
    ctx.shadowBlur = 18;
    ctx.fillStyle = `hsla(${this.hue}, 85%, ${this.lightness}%, ${alpha})`;
    ctx.fillText(this.word, this.x, this.y);

    // inner bright core
    ctx.shadowBlur = 6;
    ctx.fillStyle = `hsla(${this.hue}, 80%, 92%, ${alpha * 0.5})`;
    ctx.fillText(this.word, this.x, this.y);

    ctx.restore();
  }
}

class Dust {
  constructor() { this.init(); }
  init() {
    this.x = Math.random() * W;
    this.y = Math.random() * H;
    this.r = 0.6 + Math.random() * 1.8;
    this.alpha = 0.1 + Math.random() * 0.3;
    this.phase = Math.random() * Math.PI * 2;
    this.dx = (Math.random() - 0.5) * 0.15;
    this.dy = -0.08 - Math.random() * 0.12;
    this.hue = 330 + Math.random() * 40;
  }
  update() {
    this.x += this.dx;
    this.y += this.dy;
    if (this.y < -10) { this.y = H + 10; this.x = Math.random() * W; }
  }
  draw(t) {
    const a = this.alpha * (0.6 + Math.sin(t * 0.8 + this.phase) * 0.4);
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
    ctx.fillStyle = `hsla(${this.hue}, 80%, 75%, ${a})`;
    ctx.fill();
  }
}

function build() {
  particles.length = 0;
  dust.length = 0;
  for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(new Particle(i));
  for (let i = 0; i < DUST_COUNT; i++) dust.push(new Dust());
}

function resize() {
  W = window.innerWidth;
  H = window.innerHeight;
  canvas.width = W * DPR;
  canvas.height = H * DPR;
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.setTransform(1, 0, 0, 1, 0, 0);
  ctx.scale(DPR, DPR);
  CX = W / 2;
  CY = H / 2;
  SCALE = Math.min(W, H) * 0.014;
  build();
}

// ── Render ─────────────────────────────────────────────────────────────────
let time = 0;
function drawVignette() {
  const g = ctx.createRadialGradient(CX, CY, H * 0.1, CX, CY, H * 0.85);
  g.addColorStop(0, 'rgba(0,0,0,0)');
  g.addColorStop(1, 'rgba(2,0,8,0.82)');
  ctx.fillStyle = g;
  ctx.fillRect(0, 0, W, H);
}

function drawHeartOutline(t) {
  const pulse = 1 + Math.sin(t * 1.5) * 0.018;
  ctx.beginPath();
  const N = 300;
  for (let i = 0; i <= N; i++) {
    const angle = (i / N) * Math.PI * 2;
    const p = heartXY(angle);
    const px = CX + p.x * pulse;
    const py = CY + p.y * 0.92 * pulse - H * 0.06;
    i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
  }
  ctx.closePath();
  ctx.strokeStyle = `rgba(220, 60, 100, ${0.08 + Math.sin(t * 1.5) * 0.04})`;
  ctx.lineWidth = 1;
  ctx.stroke();
}

function animate() {
  ctx.clearRect(0, 0, W, H);
  time += 0.022;

  // dust
  dust.forEach(d => { d.update(); d.draw(time); });

  // heart outline ghost
  drawHeartOutline(time);

  // particles
  particles.forEach(p => { p.update(time); p.draw(time); });

  // vignette on top
  drawVignette();

  requestAnimationFrame(animate);
}

resize();
window.addEventListener('resize', resize);
animate();
</script>
</body>
</html>
